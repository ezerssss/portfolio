---
import { getCollection } from "astro:content";
import { nameToColor } from "../util/color";

const work = await getCollection("work");
const sorted = work.toSorted((a, b) => b.data.order - a.data.order);
---

<section
    id="work"
    class="lg:px-8 lg:sticky lg:top-6 lg:pt-5 lg:pb-8 rounded-xl lg:border lg:border-[#1db6a5]/40 h-fit w-fit space-y-5 lg:min-w-105"
>
    <h2 class="font-semibold text-lg">Work</h2>

    <div class="space-y-8">
        {
            sorted.map((work) => {
                const { data } = work;
                const { name, position, date } = data;
                const backgroundColor = nameToColor(name);

                return (
                    <article class="flex gap-3 items-start">
                        <div
                            class="rounded-xl aspect-square h-10 flex items-center justify-center "
                            style={`background-color: ${backgroundColor}`}
                        >
                            <p class="font-black m-0">{name[0]}</p>
                        </div>

                        <div class="space-y-1 w-full">
                            <p class="text-sm font-semibold">{name}</p>

                            <div class="-space-y-0.5">
                                <div class="flex gap-10 text-[12px] justify-between">
                                    <p class="text-white/55">{position}</p>

                                    <time class="text-gray-500/85">{date}</time>
                                </div>
                            </div>
                        </div>
                    </article>
                );
            })
        }
    </div>
</section>
