---
import { getCollection } from "astro:content";
import { nameToColor } from "../util/color";

const work = await getCollection("work");
const sorted = work.toSorted((a, b) => {
    const dateA = new Date(a.data.dateStart).toISOString();
    const dateB = new Date(b.data.dateStart).toISOString();

    return dateB.localeCompare(dateA);
});
---

<section
    id="work"
    class="lg:px-7 lg:sticky lg:top-6 lg:pt-4 lg:pb-7 rounded-xl lg:border lg:border-[#1db6a5]/40 h-fit w-fit space-y-5 lg:min-w-120"
>
    <h2 class="font-semibold text-lg">Experience</h2>

    <div class="space-y-8 w-full">
        {
            sorted.map((work) => {
                const { data } = work;
                const { name, position, dateStart, dateEnd, image, color } =
                    data;
                const backgroundColor = nameToColor(name);

                return (
                    <article class="flex gap-3 w-full items-start">
                        <div
                            class="rounded-xl overflow-hidden h-10! min-w-10! aspect-square! flex items-center justify-center object-fit"
                            style={`background-color: ${color ?? backgroundColor}`}
                        >
                            {image ? (
                                <img src={`/images/${image}`} class="h-full" />
                            ) : (
                                <p class="font-black m-0">{name[0]}</p>
                            )}
                        </div>

                        <div class="space-y-1 w-full">
                            <p class="text-sm font-semibold">{name}</p>

                            <div class="-space-y-0.5">
                                <div class="flex gap-10 text-[12px] justify-between">
                                    <p class="text-white/55">{position}</p>

                                    <time class="text-gray-500/85">
                                        {dateStart} - {dateEnd}
                                    </time>
                                </div>
                            </div>
                        </div>
                    </article>
                );
            })
        }
    </div>
</section>
