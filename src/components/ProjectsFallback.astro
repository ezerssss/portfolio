            <time class="flex items-center gap-3 text-[12px] text-white/55">
                <p>|</p>
                <div class="h-3 rounded w-15 bg-gray-300/55 animate-pulse">
                </div>
            </time>

            <div class="mt-1 mb-0.5 flex gap-1 items-center">
                <div class="h-4 w-4/5 rounded bg-gray-300/55 animate-pulse">
                </div>
            </div>

            <div
                class="h-3.5 mt-3.5 rounded w-3/5 bg-gray-300/55 animate-pulse"
            >
            </div>
            <div
                class="h-3.5 mt-0.5 rounded w-2/5 bg-gray-300/55 animate-pulse"
            >
            </div>

            <p
                class="text-[12px] text-[#1db6a5] mt-3 group-hover:underline invisible"
            >
